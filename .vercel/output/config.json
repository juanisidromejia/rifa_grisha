{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/assign-raffle-numbers/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/confirm-payment/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/congratulate-winner/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/logout/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/save-raffle-numbers/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/send-raffles/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/users/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/register-email/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/send-payment-data/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/test/?$",
			"dest": "_render"
		}
	],
	"images": {
		"sizes": [
			640,
			750,
			828,
			1080,
			1200,
			1920,
			2048,
			3840
		],
		"domains": [],
		"remotePatterns": []
	}
}